# Copy to .env.local and fill in. Never commit .env.local.

# Web + Worker (from Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Worker only (keep out of apps/web/**)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PANDASCORE_API_KEY=
PANDASCORE_BASE_URL=https://api.pandascore.co

# Optional worker tuning
WORKER_POLL_MS_RUNNING=45000
WORKER_POLL_MS_DETAIL=30000
WORKER_POLL_MS_CATALOG=600000
